#!/bin/bash
set -uo pipefail
IFS=$'\n\t'

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; B='\033[0;34m'; C='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

error() { echo -e "${R}[ERR]${NC}  $1"; exit 1; }

cwd() {
    source=${BASH_SOURCE[0]}
    while [ -L "$source" ]; do
        target="$(readlink "$source")"
        if [[ $target == /* ]]; then
            source="$target"
        else
            dir="$(dirname "$source")"
            source="$dir/$target"
        fi
    done
    dirname "$source"
}

banner() {
    echo -e "${C}=================================${NC}"
    echo -e "${C}   POCKER - Non Root Container   ${NC}"
    echo -e "${C}=================================${NC}"
}

help() {
    banner
    echo -e ""
    echo -e "Usage: $0 <command> <args...>"
    echo -e "Commands:"
    echo -e "  - ${BOLD}pull${NC} <image>[:tag]"
    echo -e "  - ${BOLD}create${NC} <image> <container_name>"
    echo -e "  - ${BOLD}login${NC} <container_name>"
    echo -e "  - ${BOLD}delete${NC} <image>"
    echo -e "  - ${BOLD}delete-container${NC} <container_name>"
    exit 0
}

resolve_image_name() {
    RAW_IMAGE="$1"
    if [[ "$RAW_IMAGE" =~ ^([^/]+\.[^/]+)/(.+)$ ]]; then
        REPO_TAG="${BASH_REMATCH[2]}"
    else
        REPO_TAG="$RAW_IMAGE"
        [[ "$REPO_TAG" != *"/"* ]] && REPO_TAG="library/$REPO_TAG"
    fi

    echo $REPO_TAG
}

alphanum() {
    echo "$1" | sed -e 's/[^a-zA-Z0-9]/_/g'
}

regsave() {
    printf '%s\n' "$1" | sed -e 's/[][(){}.^$*+?|\\/]/\\&/g'
}

if [ $# -lt 2 ] || [ "$1" = "help" ]; then
    help
fi

CACHE_DIR="$(cwd)/.cache"
ROOTFS_DIR="$(cwd)/.rootfs"
CACHE_STATE="$CACHE_DIR/state"
ROOTFS_STATE="$ROOTFS_DIR/state"

[ ! -e "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"
[ ! -e "$ROOTFS_DIR" ] && mkdir -p "$ROOTFS_DIR"
[ ! -f "$ROOTFS_STATE" ] && touch "$ROOTFS_STATE"
[ ! -f "$CACHE_STATE" ] && touch "$CACHE_STATE"


command="$1"
case $command in
    pull)
        image="$2"
        path="$(alphanum "$image")"
        full_image="$(resolve_image_name "$image")"

        if grep -q "^$full_image " "$CACHE_STATE"; then
            error "$image already installed."
        fi

        echo "Pulling image.."
        [ $? -eq 0 ] && printf "$full_image $path\n" >> "$CACHE_STATE"
        ;;
    create)
        image="$2"
        container="$3"
        image_path="$(alphanum "$image")"
        full_image="$(resolve_image_name "$image")"
        container_path="$(alphanum "$container")"

        if [ ! -e "$CACHE_DIR/$image_path" ] && ! grep -q "^$full_image" "$CACHE_STATE"; then
            error "$image is not installed."
        fi

        if [ -e "$ROOTFS_DIR/$container_path" ] || awk -F'\t' -v c="$container" '$2==c{found=1; exit} END{exit !found}' "$ROOTFS_STATE" > /dev/null 2>&1; then
            error "container named '$container' already exists."
        fi

        echo "Creating container $image -> $container.."
        printf "$full_image\t$container\t$container_path\n" >> "$ROOTFS_STATE"
        ;;
    ls)
        case "$2" in
            image)
                cat "$CACHE_STATE" | awk '{print $1}'
                ;;
            container)
                awk '{ printf "%-8s | %s\n", $2, $1 }' "$ROOTFS_STATE"
                ;;
            *) help;;
        esac
        ;;
    login)
        echo "Login into container.."
        ;;
    delete)
        image="$2"
        path="$(alphanum "$image")"
        full_image="$(resolve_image_name "$image")"
        regex="^$(regsave "$full_image") "
        target="$CACHE_DIR/$path"

        if [ ! -e "$target" ] && ! grep -q "^$full_image " "$CACHE_STATE"; then
            error "$image is not installed."
        fi

        rm -rf "$target"
        sed -i "/$regex/d" "$CACHE_STATE"
        echo -e "${G}[OK]${NC}  $image deleted."
        ;;
    "delete-container")
        container="$2"
        path="$(alphanum "$container")"
        target="$ROOTFS_DIR/$path"

        if [ ! -e "$target" ] && ! awk -F'\t' -v c="$container" '$2==c{found=1; exit} END{exit !found}' "$ROOTFS_STATE" > /dev/null 2>&1; then
            error "$container is not installed."
        fi

        rm -rf "$target"
        sed -i "/\t$(regsave "$container")\t/d" "$ROOTFS_STATE"
        echo -e "${G}[OK]${NC}  $container deleted."
        ;;
    *)
        help
        ;;
esac
